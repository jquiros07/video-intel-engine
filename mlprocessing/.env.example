# For local dev with docker-compose use the standard postgres URL below.
# For Azure use: postgresql://<user>:<pass>@<server>.postgres.database.azure.com:5432/video_intel?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/video_intel

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account-name;AccountKey=your-account-key;EndpointSuffix=core.windows.net
AZURE_QUEUE_NAME=video-processing-queue
AZURE_BLOB_CONTAINER_NAME=videos

# URL of the API service used to send completion notifications.
# For local dev: http://localhost:8080/api
# For Azure: https://<api-container-app-fqdn>/api
API_BASE_URL=http://localhost:8080/api

# Must match SERVICE_SECRET set on the API.
SERVICE_SECRET=replace-with-a-long-random-secret

# "loop" keeps the worker polling continuously (local dev / docker-compose).
# "job" processes one message and exits (Azure ACA event-driven job).
WORKER_MODE=loop

# YOLO model file baked into the Docker image. Override only if using a different model.
YOLO_MODEL=yolov8n.pt
