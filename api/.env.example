JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
# In minutes
JWT_EXPIRATION=60

PORT=8080
VIDEO_UPLOAD_LIMIT=50mb
VIDEO_UPLOAD_PARSER_LIMIT=100mb

# For local dev with docker-compose use the standard postgres URL below.
# For Azure use: postgresql://<user>:<pass>@<server>.postgres.database.azure.com:5432/video_intel?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/video_intel?schema=public

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account-name;AccountKey=your-account-key;EndpointSuffix=core.windows.net
AZURE_QUEUE_NAME=video-processing-queue
AZURE_BLOB_CONTAINER_NAME=videos
# Optional. Leave empty to use the Azure blob URL returned by the SDK.
AZURE_BLOB_PUBLIC_BASE_URL=

# Shared secret used by the processor to call /internal/send-email.
# Must match SERVICE_SECRET set on the processor.
SERVICE_SECRET=replace-with-a-long-random-secret

# Optional — email notifications are skipped if these are not set.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Video Intel Engine
